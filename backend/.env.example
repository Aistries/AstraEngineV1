# ============================================================
# ASTRA Intelligence Engine
# Environment Configuration
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
APP_NAME=ASTRA Intelligence Engine
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
POSTGRES_DB=astra

POSTGRES_USER=astra

POSTGRES_PASSWORD=astra_password

POSTGRES_HOST=postgres

POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://astra:astra_password@postgres:5432/astra

# ------------------------------------------------------------
# Redis
# ------------------------------------------------------------
REDIS_HOST=redis

REDIS_PORT=6379

REDIS_DB=0

REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------
# Dramatiq
# ------------------------------------------------------------
DRAMATIQ_BROKER=redis://redis:6379/0

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
LOG_LEVEL=INFO

LOG_FORMAT=console

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
PROMETHEUS_ENABLED=true

# ------------------------------------------------------------
# AI Providers
# ------------------------------------------------------------
AI_PROVIDER=none

OPENAI_API_KEY=

OLLAMA_URL=http://host.docker.internal:11434

# ------------------------------------------------------------
# Search
# ------------------------------------------------------------
OPENSEARCH_HOST=opensearch

OPENSEARCH_PORT=9200

# ------------------------------------------------------------
# Storage
# ------------------------------------------------------------
MINIO_ENDPOINT=minio:9000

MINIO_ACCESS_KEY=minio

MINIO_SECRET_KEY=minio123

MINIO_BUCKET=astra

# ------------------------------------------------------------
# Email
# ------------------------------------------------------------
SMTP_HOST=

SMTP_PORT=587

SMTP_USER=

SMTP_PASSWORD=

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
ALLOWED_ORIGINS=*